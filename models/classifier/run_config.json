{
  "pt_file": "bert_bug_model.pt",
  "base_model": "bert-base-uncased",
  "max_length": 256,
  "epochs": 10,
  "batch_size": 8,
  "grad_accum": 4,
  "lr": 2e-05,
  "weight_decay": 0.01,
  "dropout": 0.2,
  "label_smoothing": 0.05,
  "rebalance_power": 0.3,
  "lw_bugtype": 1.0,
  "lw_severity": 1.5,
  "lw_fixingtime": 1.5,
  "label_maps": {
    "Bug_Type": {
      "Crash": 0,
      "Freeze": 1,
      "Memory": 2,
      "Other": 3,
      "UI/Visual": 4
    },
    "Severity": {
      "CRITICAL": 0,
      "MAJOR": 1,
      "MINOR": 2
    },
    "Fixing_time": {
      "fast": 0,
      "medium": 1,
      "slow": 2
    }
  }
}